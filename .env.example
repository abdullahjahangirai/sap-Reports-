# Copy this file to .env.local for local development.
# On Vercel: Project Settings → Environment Variables

# SAP OData / RFC connection (when integrating live data)
# VITE_SAP_API_URL=https://your-sap-instance.example.com
# VITE_SAP_CLIENT_ID=your-client-id

# AI Agent / LLM API keys (never hardcode in source)
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# n8n webhook endpoints (for live automation triggers)
# VITE_N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/...

# Analytics (optional)
# VITE_ANALYTICS_ID=your-analytics-id
